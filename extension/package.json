{
  "name": "opendaemon",
  "displayName": "OpenDaemon",
  "description": "Orchestrate local development services with declarative configuration",
  "version": "0.1.0",
  "publisher": "opendaemon",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/opendaemon/opendaemon"
  },
  "homepage": "https://github.com/opendaemon/opendaemon#readme",
  "bugs": {
    "url": "https://github.com/opendaemon/opendaemon/issues"
  },
  "keywords": [
    "opendaemon",
    "orchestration",
    "services",
    "devtools"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:dmn.json",
    "onView:opendaemon.services"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "terminal": {
      "profiles": [
        {
          "id": "opendaemon.terminal",
          "title": "OpenDaemon CLI"
        }
      ]
    },
    "commands": [
      {
        "command": "opendaemon.startAll",
        "title": "Start All Services",
        "category": "OpenDaemon",
        "icon": "$(play)"
      },
      {
        "command": "opendaemon.stopAll",
        "title": "Stop All Services",
        "category": "OpenDaemon",
        "icon": "$(debug-stop)"
      },
      {
        "command": "opendaemon.startService",
        "title": "Start Service",
        "category": "OpenDaemon",
        "icon": "$(play)"
      },
      {
        "command": "opendaemon.stopService",
        "title": "Stop Service",
        "category": "OpenDaemon",
        "icon": "$(debug-stop)"
      },
      {
        "command": "opendaemon.restartService",
        "title": "Restart Service",
        "category": "OpenDaemon",
        "icon": "$(refresh)"
      },
      {
        "command": "opendaemon.showLogs",
        "title": "Show Logs",
        "category": "OpenDaemon",
        "icon": "$(output)"
      },
      {
        "command": "opendaemon.showTerminal",
        "title": "Open Terminal",
        "category": "OpenDaemon",
        "icon": "$(terminal)"
      },
      {
        "command": "opendaemon.refresh",
        "title": "Refresh Services",
        "category": "OpenDaemon",
        "icon": "$(refresh)"
      },
      {
        "command": "opendaemon.newTerminalWithCLI",
        "title": "New Terminal with CLI",
        "category": "OpenDaemon",
        "icon": "$(terminal)"
      },
      {
        "command": "opendaemon.showCLIInfo",
        "title": "Show CLI Info",
        "category": "OpenDaemon"
      },
      {
        "command": "opendaemon.installCLIGlobally",
        "title": "Install CLI Globally",
        "category": "OpenDaemon"
      },
      {
        "command": "opendaemon.showCLILogs",
        "title": "Show CLI Logs",
        "category": "OpenDaemon"
      },
      {
        "command": "opendaemon.runCLIDiagnostics",
        "title": "Run CLI Diagnostics",
        "category": "OpenDaemon"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "opendaemon.services",
          "name": "OpenDaemon Services"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "opendaemon.startAll",
          "when": "view == opendaemon.services",
          "group": "navigation@1"
        },
        {
          "command": "opendaemon.stopAll",
          "when": "view == opendaemon.services",
          "group": "navigation@2"
        },
        {
          "command": "opendaemon.refresh",
          "when": "view == opendaemon.services",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "opendaemon.startService",
          "when": "view == opendaemon.services && viewItem == service",
          "group": "inline@1"
        },
        {
          "command": "opendaemon.stopService",
          "when": "view == opendaemon.services && viewItem == service",
          "group": "inline@2"
        },
        {
          "command": "opendaemon.restartService",
          "when": "view == opendaemon.services && viewItem == service",
          "group": "inline@3"
        },
        {
          "command": "opendaemon.showLogs",
          "when": "view == opendaemon.services && viewItem == service",
          "group": "navigation@1"
        },
        {
          "command": "opendaemon.showTerminal",
          "when": "view == opendaemon.services && viewItem == service",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "package:pre-release": "vsce package --pre-release"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.54.0",
    "fast-check": "^4.5.3",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2"
  }
}